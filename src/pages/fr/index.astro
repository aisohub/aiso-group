---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AISO Group",
  "alternateName": ["AISO", "AISO Group", "AISO Portugal"],
  "url": "https://aiso-group.com",
  "logo": "https://aiso-group.com/images/logo/aiso-group-negative.svg",
  "description": "AISO is the specialist AI group based in Lisbon, Portugal. Four AI companies under one roof: AI search (Hub), AI systems (Dev), AI-powered social (Buzz), AI training (Learn).",
  "areaServed": [
    { "@type": "Country", "name": "Portugal" },
    { "@type": "Country", "name": "France" },
    { "@type": "Country", "name": "Belgium" },
    { "@type": "Country", "name": "Switzerland" },
    { "@type": "Country", "name": "Luxembourg" }
  ],
  "foundingDate": "2025",
  "foundingLocation": { "@type": "Place", "name": "Lisbon, Portugal" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Avenida David Mourão-Ferreira 14, 8A",
    "postalCode": "1750-204",
    "addressLocality": "Lisboa",
    "addressCountry": "PT"
  },
  "parentOrganization": {
    "@type": "Organization",
    "name": "Precious Episode LDA",
    "taxID": "514701617",
    "vatID": "PT514701617",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Avenida David Mourão-Ferreira 14, 8A",
      "postalCode": "1750-204",
      "addressLocality": "Lisboa",
      "addressCountry": "PT"
    }
  },
  "subOrganization": [
    { "@type": "Organization", "name": "AISO Learn", "url": "https://aiso-learn.com", "description": "Corporate AI training and EU AI Act compliance" },
    { "@type": "Organization", "name": "AISO Dev", "url": "https://aiso-dev.com", "description": "AI implementation partner for SMBs" },
    { "@type": "Organization", "name": "AISO Hub", "url": "https://aiso-hub.com", "description": "AI Search Optimization agency" },
    { "@type": "Organization", "name": "AISO Buzz", "url": "https://aiso-buzz.com", "description": "AI-powered social and content agency" }
  ],
  "sameAs": [
    "https://aiso-hub.com",
    "https://aiso-dev.com",
    "https://aiso-buzz.com",
    "https://aiso-learn.com",
    "https://www.linkedin.com/company/aiso-hub",
    "https://github.com/aisohub"
  ],
  "founder": { "@type": "Person", "name": "Greg Stoos" },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hello@aiso-group.com",
    "contactType": "customer service",
    "availableLanguage": ["en", "pt", "fr"]
  }
};

const webSiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AISO Group",
  "alternateName": "AISO",
  "url": "https://aiso-group.com",
  "publisher": { "@type": "Organization", "name": "AISO Group" },
  "inLanguage": ["en", "pt-PT", "fr-FR"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://aiso-group.com/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};
---

<Base
  title={t.home.meta.title}
  description={t.home.meta.description}
  jsonLd={[orgJsonLd, webSiteJsonLd]}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-24 md:!py-32">
      <span class="kicker kicker-on-dark mb-5 block">{t.home.hero.kicker}</span>
      <h1 class="h1 !text-white max-w-4xl">{t.home.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6">{t.home.hero.lead}</p>
      <div class="mt-9 flex flex-col sm:flex-row gap-3">
        <a href="#router" class="btn btn-on-dark">{t.home.hero.ctaPrimary}</a>
        <a href={p('/contact/')} class="btn btn-ghost-on-dark">{t.home.hero.ctaSecondary}</a>
      </div>
    </div>
  </section>

  <section id="router" class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-2xl mb-10">
        <span class="kicker mb-3">{t.home.router.kicker}</span>
        <h2 class="h2">{t.home.router.title}</h2>
        <p class="lead mt-4">{t.home.router.lead}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <article class="router-card" style="--accent: #00d492;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">{t.home.router.hub.question}</p>
          <h3 class="router-card__answer">{t.home.router.hub.answer}</h3>
          <p class="router-card__audience">{t.home.router.hub.audience}</p>
          <a class="router-card__cta" href="https://aiso-hub.com" rel="noopener">{t.home.router.hub.cta}</a>
        </article>

        <article class="router-card" style="--accent: #3B82F6;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">{t.home.router.dev.question}</p>
          <h3 class="router-card__answer">{t.home.router.dev.answer}</h3>
          <p class="router-card__audience">{t.home.router.dev.audience}</p>
          <a class="router-card__cta" href="https://aiso-dev.com" rel="noopener">{t.home.router.dev.cta}</a>
        </article>

        <article class="router-card" style="--accent: #F97316;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">{t.home.router.buzz.question}</p>
          <h3 class="router-card__answer">{t.home.router.buzz.answer}</h3>
          <p class="router-card__audience">{t.home.router.buzz.audience}</p>
          <a class="router-card__cta" href="https://aiso-buzz.com" rel="noopener">{t.home.router.buzz.cta}</a>
        </article>

        <article class="router-card" style="--accent: #8B5CF6;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">{t.home.router.learn.question}</p>
          <h3 class="router-card__answer">{t.home.router.learn.answer}</h3>
          <p class="router-card__audience">{t.home.router.learn.audience}</p>
          <a class="router-card__cta" href="https://aiso-learn.com" rel="noopener">{t.home.router.learn.cta}</a>
        </article>
      </div>

      <div class="mt-10 p-6 rounded-2xl border border-slate-200 bg-slate-50 flex flex-col sm:flex-row justify-between gap-4 items-start sm:items-center">
        <div>
          <p class="text-sm font-semibold text-[#0A1628]">{t.home.router.fallback.question}</p>
          <p class="text-sm text-slate-600 mt-1">{t.home.router.fallback.subtitle}</p>
        </div>
        <a href={p('/contact/')} class="btn btn-primary whitespace-nowrap">{t.home.router.fallback.cta}</a>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="container-aiso section">
      <span class="kicker mb-3 block">{t.home.verbTest.kicker}</span>
      <h2 class="h2 mb-8">{t.home.verbTest.title}</h2>
      <div class="sibling-strip">
        <div class="sibling-strip__item" style="--accent: #00d492;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">{t.home.verbTest.hubKicker}</p>
          <p class="text-lg text-[#0A1628] mt-1">{t.home.verbTest.hubLine}</p>
        </div>
        <div class="sibling-strip__item" style="--accent: #3B82F6;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">{t.home.verbTest.devKicker}</p>
          <p class="text-lg text-[#0A1628] mt-1">{t.home.verbTest.devLine}</p>
        </div>
        <div class="sibling-strip__item" style="--accent: #F97316;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">{t.home.verbTest.buzzKicker}</p>
          <p class="text-lg text-[#0A1628] mt-1">{t.home.verbTest.buzzLine}</p>
        </div>
        <div class="sibling-strip__item" style="--accent: #8B5CF6;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">{t.home.verbTest.learnKicker}</p>
          <p class="text-lg text-[#0A1628] mt-1">{t.home.verbTest.learnLine}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-3xl">
        <span class="kicker mb-3 block">{t.home.founder.kicker}</span>
        <h2 class="h2 mb-6">{t.home.founder.title}</h2>
        <div class="article-body">
          <p>{t.home.founder.p1}</p>
          <p>{t.home.founder.p2}</p>
          <p>{t.home.founder.p3}</p>
          <p>{t.home.founder.p4}</p>
          <p class="text-sm text-slate-500 mt-6">{t.home.founder.signature}</p>
        </div>
        <div class="mt-8">
          <a href={p('/about/')} class="btn btn-ghost">{t.home.founder.cta}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
