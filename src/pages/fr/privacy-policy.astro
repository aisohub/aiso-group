---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);

const updated = '2026-04-17';
---

<Base
  title={t.privacy.meta.title}
  description={t.privacy.meta.description}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-16 md:!py-24">
      <span class="kicker kicker-on-dark mb-4 block">{t.privacy.hero.kicker}</span>
      <h1 class="h1 !text-white">{t.privacy.hero.title}</h1>
      <p class="text-sm text-slate-400 mt-4">{t.privacy.hero.updatedLabel} {updated}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="article-body">
        <h2>{t.privacy.whoHeading}</h2>
        <p>{t.privacy.whoBody}</p>

        <h2>{t.privacy.collectHeading}</h2>
        <p set:html={t.privacy.collectIntro} />
        <ul>
          <li set:html={t.privacy.collectForm} />
          <li set:html={t.privacy.collectEmail} />
          <li set:html={t.privacy.collectLogs} />
        </ul>
        <p>{t.privacy.collectNote}</p>

        <h2>{t.privacy.useHeading}</h2>
        <ul>
          <li>{t.privacy.use1}</li>
          <li>{t.privacy.use2}</li>
          <li>{t.privacy.use3}</li>
        </ul>
        <p>{t.privacy.useNote}</p>

        <h2>{t.privacy.accessHeading}</h2>
        <ul>
          <li set:html={t.privacy.access1} />
          <li set:html={t.privacy.access2} />
          <li set:html={t.privacy.access3} />
        </ul>

        <h2>{t.privacy.rightsHeading}</h2>
        <p set:html={t.privacy.rightsBody} />

        <h2>{t.privacy.retentionHeading}</h2>
        <p>{t.privacy.retentionBody}</p>

        <h2>{t.privacy.changesHeading}</h2>
        <p>{t.privacy.changesBody}</p>

        <h2>{t.privacy.contactHeading}</h2>
        <p set:html={t.privacy.contactAddress} />
      </div>
    </div>
  </section>
</Base>
