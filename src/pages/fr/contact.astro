---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact AISO Group",
  "url": "https://aiso-group.com/contact/",
  "description": "Not sure which specialist you need? Book a 20-minute call. Greg routes you to the right AISO brand."
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://aiso-group.com/contact/" }
  ]
};
---

<Base
  title={t.contact.meta.title}
  description={t.contact.meta.description}
  jsonLd={[contactJsonLd, breadcrumbJsonLd]}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">{t.contact.hero.kicker}</span>
      <h1 class="h1 !text-white max-w-3xl">{t.contact.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6 max-w-2xl">{t.contact.hero.lead}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3">
          <span class="kicker mb-3 block">{t.contact.form.kicker}</span>
          <h2 class="h2">{t.contact.form.title}</h2>

          <form
            class="mt-8 flex flex-col gap-5"
            action="/api/contact"
            method="POST"
            id="contact-form"
            data-status-routing={t.contact.form.statusRouting}
            data-status-success={t.contact.form.statusSuccess}
            data-status-fallback={t.contact.form.statusFallback}
            data-mail-subject={t.contact.form.mailSubject}
          >
            <div class="form-field">
              <label for="name">{t.contact.form.nameLabel}</label>
              <input id="name" name="name" type="text" required autocomplete="name" placeholder={t.contact.form.namePlaceholder} />
            </div>
            <div class="form-field">
              <label for="company">{t.contact.form.companyLabel}</label>
              <input id="company" name="company" type="text" required autocomplete="organization" placeholder={t.contact.form.companyPlaceholder} />
            </div>
            <div class="form-field">
              <label for="message">{t.contact.form.messageLabel}</label>
              <textarea id="message" name="message" rows="4" required placeholder={t.contact.form.messagePlaceholder}></textarea>
            </div>
            <div class="form-field">
              <label for="email">{t.contact.form.emailLabel}</label>
              <input id="email" name="email" type="email" autocomplete="email" placeholder={t.contact.form.emailPlaceholder} />
            </div>
            <div class="flex items-center gap-4">
              <button type="submit" class="btn btn-primary">{t.contact.form.submit}</button>
              <p class="text-xs text-slate-500">{t.contact.form.submitHelp}</p>
            </div>
            <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
          </form>
        </div>

        <aside class="lg:col-span-2 flex flex-col gap-8">
          <div>
            <span class="kicker mb-3 block">{t.contact.sidebar.knowKicker}</span>
            <h3 class="h3 mb-4">{t.contact.sidebar.knowHeading}</h3>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-hub.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#00d492;"></span> {t.contact.sidebar.hubLine}</a></li>
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-dev.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#3B82F6;"></span> {t.contact.sidebar.devLine}</a></li>
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-buzz.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#F97316;"></span> {t.contact.sidebar.buzzLine}</a></li>
            </ul>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200">
            <span class="kicker mb-2 block">{t.contact.sidebar.calendarKicker}</span>
            <p class="text-sm text-slate-600 mb-4">{t.contact.sidebar.calendarBody}</p>
            <a class="btn btn-primary" href="mailto:hello@aiso-group.com?subject=20-min%20triage">{t.contact.sidebar.calendarCta}</a>
          </div>
          <div>
            <span class="kicker mb-2 block">{t.contact.sidebar.nextKicker}</span>
            <ol class="flex flex-col gap-3 text-sm text-slate-600 list-decimal list-inside">
              <li set:html={t.contact.sidebar.next1} />
              <li set:html={t.contact.sidebar.next2} />
              <li set:html={t.contact.sidebar.next3} />
            </ol>
          </div>
          <div>
            <span class="kicker mb-2 block">{t.contact.sidebar.notDoKicker}</span>
            <ul class="flex flex-col gap-2 text-sm text-slate-600 list-disc list-inside">
              <li>{t.contact.sidebar.notDo1}</li>
              <li>{t.contact.sidebar.notDo2}</li>
              <li>{t.contact.sidebar.notDo3}</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    // Progressive enhancement: POST via fetch. If /api/contact is not wired yet
    // fall back to a mailto so users aren't blocked. Strings pulled from the
    // form's data-* attributes (localised in frontmatter).
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !status) return;
      const data = new FormData(form);
      const routingMsg = form.dataset.statusRouting || 'Routing…';
      const successMsg = form.dataset.statusSuccess || 'Thanks.';
      const fallbackMsg = form.dataset.statusFallback || 'Opened your mail client.';
      const mailSubjectPrefix = form.dataset.mailSubject || 'AISO Group inbound';
      status.textContent = routingMsg;
      try {
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        if (res.ok) {
          status.className = 'text-sm text-emerald-700';
          status.textContent = successMsg;
          form.reset();
        } else {
          throw new Error('bad-status');
        }
      } catch {
        const name = String(data.get('name') || '');
        const company = String(data.get('company') || '');
        const msg = String(data.get('message') || '');
        const email = String(data.get('email') || '');
        const body = `Name: ${name}%0D%0ACompany: ${company}%0D%0AEmail: ${email}%0D%0A%0D%0A${encodeURIComponent(msg)}`;
        window.location.href = `mailto:hello@aiso-group.com?subject=${encodeURIComponent(mailSubjectPrefix + ' — ' + (company || name))}&body=${body}`;
        status.className = 'text-sm text-slate-600';
        status.textContent = fallbackMsg;
      }
    });
  </script>
</Base>
