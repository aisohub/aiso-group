---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getDictionary } from '../../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "News", "item": "https://aiso-group.com/news/" }
  ]
};

function fmt(d: Date, loc: Locale) {
  const tag = loc === 'pt-pt' ? 'pt-PT' : loc === 'fr' ? 'fr-FR' : 'en-GB';
  return d.toLocaleDateString(tag, { year: 'numeric', month: 'long', day: 'numeric' });
}

const categoryLabel = (key: string): string =>
  (t.news.categories as Record<string, string>)[key] ?? key;
---

<Base
  title={t.news.meta.title}
  description={t.news.meta.description}
  jsonLd={breadcrumbJsonLd}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">{t.news.hero.kicker}</span>
      <h1 class="h1 !text-white">{t.news.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6">{t.news.hero.lead}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-3xl article-body mb-14">
        <p>{t.news.intro.p1}</p>
        <p set:html={t.news.intro.p2} />
        <p>{t.news.intro.p3}</p>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <li>
            <a
              href={`${p('/news/')}${post.slug}/`}
              class="block h-full p-7 rounded-2xl border border-slate-200 hover:border-slate-400 hover:shadow-lg transition-all bg-white"
            >
              <span class="kicker">{categoryLabel(post.data.category)}</span>
              <h2 class="h3 mt-3">{post.data.title}</h2>
              <p class="text-sm text-slate-500 mt-2">
                {fmt(post.data.date, locale)} · {post.data.readTime} {t.news.card.readTimeSuffix} · {post.data.author}
              </p>
              <p class="mt-4 text-slate-700 leading-relaxed">{post.data.excerpt}</p>
              <span class="inline-block mt-4 text-sm font-semibold text-[#0A1628]">{t.news.card.readCta}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="container-aiso section !py-16">
      <div class="max-w-3xl">
        <h2 class="h2">{t.news.routerFallback.title}</h2>
        <p class="lead mt-4">{t.news.routerFallback.lead}</p>
        <a href={`${p('/')}#router`} class="btn btn-primary mt-6">{t.news.routerFallback.cta}</a>
      </div>
    </div>
  </section>
</Base>
