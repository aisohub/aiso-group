---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://aiso-group.com/about/" }
  ]
};

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About AISO Group",
  "url": "https://aiso-group.com/about/",
  "description": "We built a group, not an agency. Four specialist AI companies, one roof, one rule: specialists beat generalists for real businesses."
};
---

<Base
  title={t.about.meta.title}
  description={t.about.meta.description}
  jsonLd={[aboutJsonLd, breadcrumbJsonLd]}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">{t.about.hero.kicker}</span>
      <h1 class="h1 !text-white max-w-4xl">{t.about.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6">{t.about.hero.lead}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="article-body">
        <h2>{t.about.sections.whySpecialistHeading}</h2>
        <p>{t.about.sections.whyP1}</p>
        <p>{t.about.sections.whyP2}</p>
        <p>{t.about.sections.whyP3}</p>

        <h2>{t.about.sections.fourHeading}</h2>
        <ul>
          <li set:html={t.about.sections.fourHub} />
          <li set:html={t.about.sections.fourDev} />
          <li set:html={t.about.sections.fourBuzz} />
          <li set:html={t.about.sections.fourLearn} />
        </ul>
        <p>{t.about.sections.fourFooter}</p>

        <h2>{t.about.sections.notBeHeading}</h2>
        <ul>
          <li>{t.about.sections.notBe1}</li>
          <li>{t.about.sections.notBe2}</li>
          <li>{t.about.sections.notBe3}</li>
        </ul>

        <h2>{t.about.sections.lisbonHeading}</h2>
        <p set:html={t.about.sections.lisbonFounder} />
        <p set:html={t.about.sections.lisbonTeam} />
        <p set:html={t.about.sections.lisbonLegal} />
        <p set:html={t.about.sections.lisbonFocus} />

        <h2>{t.about.sections.rulesHeading}</h2>
        <ol>
          <li set:html={t.about.sections.rule1} />
          <li set:html={t.about.sections.rule2} />
          <li set:html={t.about.sections.rule3} />
          <li set:html={t.about.sections.rule4} />
        </ol>

        <h2>{t.about.sections.year2026Heading}</h2>
        <p>{t.about.sections.year2026P1}</p>
        <p>{t.about.sections.year2026P2}</p>
        <p>{t.about.sections.year2026P3}</p>
        <p>{t.about.sections.year2026P4}</p>

        <h2>{t.about.sections.proofHeading}</h2>
        <p set:html={t.about.sections.proofIntro} />
        <ul>
          <li set:html={t.about.sections.proofHub} />
          <li set:html={t.about.sections.proofDev} />
          <li set:html={t.about.sections.proofBuzz} />
        </ul>
        <p>{t.about.sections.proofFooter}</p>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row gap-3">
        <a href={`${p('/')}#router`} class="btn btn-primary">{t.about.sections.ctaPrimary}</a>
        <a href={p('/contact/')} class="btn btn-ghost">{t.about.sections.ctaSecondary}</a>
      </div>
    </div>
  </section>
</Base>
