---
import Base from '../layouts/Base.astro';

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact AISO Group",
  "url": "https://aiso-group.com/contact/",
  "description": "Not sure which specialist you need? Book a 20-minute call. Greg routes you to the right AISO brand."
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://aiso-group.com/contact/" }
  ]
};
---

<Base
  title="Contact — Talk to Greg"
  description="Not sure which specialist you need? Book a 20-minute call. Greg routes you to the right AISO brand — or tells you if we are the wrong call."
  jsonLd={[contactJsonLd, breadcrumbJsonLd]}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">Triage · not a sales funnel</span>
      <h1 class="h1 !text-white max-w-3xl">Not sure which specialist? Book a call.</h1>
      <p class="lead !text-slate-300 mt-6 max-w-2xl">
        20 minutes with Greg. We route you to Hub, Dev, or Buzz — or we tell you honestly if we are the wrong fit. No decks. No sales team. Triage.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3">
          <span class="kicker mb-3 block">One form. Routed by Greg.</span>
          <h2 class="h2">Three fields. No qualifying theater.</h2>

          <form
            class="mt-8 flex flex-col gap-5"
            action="/api/contact"
            method="POST"
            id="contact-form"
          >
            <div class="form-field">
              <label for="name">Your name</label>
              <input id="name" name="name" type="text" required autocomplete="name" placeholder="Full name" />
            </div>
            <div class="form-field">
              <label for="company">Company or project</label>
              <input id="company" name="company" type="text" required autocomplete="organization" placeholder="Where you work (or what you are building)" />
            </div>
            <div class="form-field">
              <label for="message">What are you looking for?</label>
              <textarea id="message" name="message" rows="4" required placeholder={'One sentence is enough. "We need AI search for a SaaS product" works. So does "Not sure, send help."'}></textarea>
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" placeholder="For the reply" />
            </div>
            <div class="flex items-center gap-4">
              <button type="submit" class="btn btn-primary">Route me</button>
              <p class="text-xs text-slate-500">Greg reads every inbound personally. Expect a reply within one business day.</p>
            </div>
            <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
          </form>
        </div>

        <aside class="lg:col-span-2 flex flex-col gap-8">
          <div>
            <span class="kicker mb-3 block">If you already know</span>
            <h3 class="h3 mb-4">Go directly to the brand</h3>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-hub.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#00d492;"></span> aiso-hub.com — AI search work</a></li>
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-dev.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#3B82F6;"></span> aiso-dev.com — AI systems / software</a></li>
              <li><a class="text-[#0A1628] font-medium hover:underline" href="https://aiso-buzz.com" rel="noopener"><span class="inline-block w-2 h-2 rounded-full align-middle mr-2" style="background:#F97316;"></span> aiso-buzz.com — Social & content</a></li>
            </ul>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200">
            <span class="kicker mb-2 block">If you want the calendar</span>
            <p class="text-sm text-slate-600 mb-4">20-minute triage with Greg. No pitch.</p>
            <a class="btn btn-primary" href="mailto:hello@aiso-group.com?subject=20-min%20triage">Email Greg →</a>
          </div>
          <div>
            <span class="kicker mb-2 block">What happens next</span>
            <ol class="flex flex-col gap-3 text-sm text-slate-600 list-decimal list-inside">
              <li><strong class="text-[#0A1628]">We read.</strong> Greg reads every form personally.</li>
              <li><strong class="text-[#0A1628]">We route.</strong> Reply within one business day — direct intro to the right team, or an honest "not us, try X."</li>
              <li><strong class="text-[#0A1628]">They scope.</strong> The specialist team (Hub, Dev, or Buzz) scopes the work with you directly.</li>
            </ol>
          </div>
          <div>
            <span class="kicker mb-2 block">What we will not do</span>
            <ul class="flex flex-col gap-2 text-sm text-slate-600 list-disc list-inside">
              <li>We will not put you on a drip sequence.</li>
              <li>We will not send a 40-slide pitch deck.</li>
              <li>We will not sell you a bundled retainer on the first call.</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    // Progressive enhancement: POST via fetch. If /api/contact is not wired yet
    // (v1 ships static — Cloudflare Pages Function will land post-merge), fall
    // back to a mailto: so users aren't blocked.
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !status) return;
      const data = new FormData(form);
      status.textContent = 'Routing…';
      try {
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        if (res.ok) {
          status.className = 'text-sm text-emerald-700';
          status.textContent = 'Thanks. Greg reads every inbound personally. Expect a reply within one business day.';
          form.reset();
        } else {
          throw new Error('bad-status');
        }
      } catch {
        // Fallback — open user's mail client. Keeps launch unblocked.
        const name = String(data.get('name') || '');
        const company = String(data.get('company') || '');
        const msg = String(data.get('message') || '');
        const email = String(data.get('email') || '');
        const body = `Name: ${name}%0D%0ACompany: ${company}%0D%0AEmail: ${email}%0D%0A%0D%0A${encodeURIComponent(msg)}`;
        window.location.href = `mailto:hello@aiso-group.com?subject=${encodeURIComponent('AISO Group inbound — ' + (company || name))}&body=${body}`;
        status.className = 'text-sm text-slate-600';
        status.textContent = 'Opened your mail client — send from there if the inline form errored.';
      }
    });
  </script>
</Base>
