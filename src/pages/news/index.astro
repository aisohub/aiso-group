---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  'announcement': 'Announcement',
  'specialist-series': 'Specialist series',
  'meta-essay': 'Meta-essay',
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "News", "item": "https://aiso-group.com/news/" }
  ]
};

function fmt(d: Date) {
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title="News & notes"
  description="Group-level strategy, announcements, and occasional essays on specialist AI for real businesses. One to two posts a month. Anti-blog by design."
  jsonLd={breadcrumbJsonLd}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">Low frequency · High signal</span>
      <h1 class="h1 !text-white">News & notes.</h1>
      <p class="lead !text-slate-300 mt-6">
        Group-level announcements. Occasional essays on specialist AI for real businesses. One to two posts a month. Never more, rarely less.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-3xl article-body mb-14">
        <p>
          This is not a content farm. We post when we have something to say — a launch, a hire, a shift in the category, a self-diagnostic tool for choosing between our brands.
        </p>
        <p>
          If you want tactical AISO writing, it lives at <a href="https://aiso-hub.com/insights" rel="noopener">aiso-hub.com/insights</a>. If you want build logs and engineering deep-dives, those live at <a href="https://aiso-dev.com" rel="noopener">aiso-dev.com</a>. If you want social and content trend teardowns, those live at <a href="https://aiso-buzz.com" rel="noopener">aiso-buzz.com</a>. If you want AI-training curricula and EU AI Act guidance, those live at <a href="https://aiso-learn.com" rel="noopener">aiso-learn.com</a>.
        </p>
        <p>This page is for the portfolio view only.</p>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <li>
            <a
              href={`/news/${post.slug}/`}
              class="block h-full p-7 rounded-2xl border border-slate-200 hover:border-slate-400 hover:shadow-lg transition-all bg-white"
            >
              <span class="kicker">{categoryLabels[post.data.category] ?? post.data.category}</span>
              <h2 class="h3 mt-3">{post.data.title}</h2>
              <p class="text-sm text-slate-500 mt-2">
                {fmt(post.data.date)} · {post.data.readTime} min read · {post.data.author}
              </p>
              <p class="mt-4 text-slate-700 leading-relaxed">{post.data.excerpt}</p>
              <span class="inline-block mt-4 text-sm font-semibold text-[#0A1628]">Read →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="container-aiso section !py-16">
      <div class="max-w-3xl">
        <h2 class="h2">Four specialists. One practical advantage.</h2>
        <p class="lead mt-4">Not sure which fits?</p>
        <a href="/#router" class="btn btn-primary mt-6">Find your AISO specialist →</a>
      </div>
    </div>
  </section>
</Base>
