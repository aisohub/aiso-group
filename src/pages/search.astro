---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getDictionary } from '../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../i18n/config';
import { STATIC_SEARCH_INDEX, searchIndex, type SearchEntry } from '../data/search-index';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

// News article slugs are merged into the index per-locale. Bodies stay EN-only
// per site spec, but the title/description used for search lookup is translated
// via the per-locale frontmatter fields on the news collection.
const newsPosts = (await getCollection('news', ({ data }) => !data.draft));

const newsEntries: SearchEntry[] = newsPosts.flatMap((post) => {
  const titleEn = post.data.title;
  const descEn = post.data.description;
  const titlePtPt = post.data.titlePtPt ?? titleEn;
  const descPtPt = post.data.descriptionPtPt ?? descEn;
  const titleFr = post.data.titleFr ?? titleEn;
  const descFr = post.data.descriptionFr ?? descEn;
  return [
    { url: `/news/${post.slug}/`, title: titleEn, description: descEn, locale: 'en' as Locale, tags: ['news', 'article', post.data.category] },
    { url: `/pt-pt/news/${post.slug}/`, title: titlePtPt, description: descPtPt, locale: 'pt-pt' as Locale, tags: ['news', 'article', post.data.category] },
    { url: `/fr/news/${post.slug}/`, title: titleFr, description: descFr, locale: 'fr' as Locale, tags: ['news', 'article', post.data.category] },
  ];
});

const fullIndex: SearchEntry[] = [...STATIC_SEARCH_INDEX, ...newsEntries];

const rawQuery = Astro.url.searchParams.get('q') ?? '';
const query = rawQuery.slice(0, 200); // hard cap to keep things sane

const localeIndex = fullIndex.filter((entry) => entry.locale === locale);
const results = query.trim() ? searchIndex(localeIndex, query) : [];

const titleSafe = (s: string) => s.replace(/[<>"'&]/g, (ch) => ({ '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;', '&': '&amp;' }[ch]!));

let resultsLabel = '';
if (query.trim()) {
  if (results.length === 0) {
    resultsLabel = t.search.noResults.replace('{query}', titleSafe(query));
  } else if (results.length === 1) {
    resultsLabel = t.search.resultsCountSingular.replace('{query}', titleSafe(query));
  } else {
    resultsLabel = t.search.resultsCount
      .replace('{count}', String(results.length))
      .replace('{query}', titleSafe(query));
  }
}

// Breadcrumb covers the canonical chain: Home -> Search.
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `https://aiso-group.com${locale === 'en' ? '/' : `/${locale}/`}` },
    { '@type': 'ListItem', 'position': 2, 'name': 'Search', 'item': `https://aiso-group.com${locale === 'en' ? '' : `/${locale}`}/search/` },
  ],
};
---

<Base
  title={t.search.meta.title}
  description={t.search.meta.description}
  jsonLd={breadcrumbJsonLd}
  noindex={true}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">{t.search.hero.kicker}</span>
      <h1 class="h1 !text-white">{t.search.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6">{t.search.hero.lead}</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <form
        method="get"
        action={p('/search/')}
        class="max-w-2xl mb-12"
        role="search"
        aria-label={t.search.form.label}
      >
        <label for="search-q" class="sr-only">{t.search.form.label}</label>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            id="search-q"
            type="search"
            name="q"
            value={query}
            placeholder={t.search.form.placeholder}
            autocomplete="off"
            class="flex-1 rounded-lg border border-slate-300 px-4 py-3 text-base focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#0A1628]"
          />
          <button type="submit" class="btn">{t.search.form.submit}</button>
        </div>
      </form>

      {!query.trim() && (
        <p class="lead text-slate-600 max-w-2xl">{t.search.emptyPrompt}</p>
      )}

      {query.trim() && (
        <>
          <p class="text-sm text-slate-600 mb-6" set:html={resultsLabel} />

          {results.length > 0 && (
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {results.map((entry) => (
                <li>
                  <a
                    href={entry.url}
                    class="block h-full p-7 rounded-2xl border border-slate-200 hover:border-slate-400 hover:shadow-lg transition-all bg-white"
                  >
                    <h2 class="h3 !text-[#0A1628] mb-2">{entry.title}</h2>
                    <p class="text-sm text-slate-600">{entry.description}</p>
                    <p class="text-xs text-slate-400 mt-3 break-all">{entry.url}</p>
                  </a>
                </li>
              ))}
            </ul>
          )}

          {results.length === 0 && (
            <div class="max-w-2xl">
              <p class="lead text-slate-600 mb-6">{t.search.noResults.replace('{query}', query)}</p>
              <a href={p('/')} class="btn btn-ghost">{t.search.backHome}</a>
            </div>
          )}
        </>
      )}
    </div>
  </section>
</Base>
