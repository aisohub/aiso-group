---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);
---

<Base
  title={t.notFound.meta.title}
  description={t.notFound.meta.description}
  hreflangDisabled={true}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-24 md:!py-32">
      <span class="kicker kicker-on-dark mb-4 block">{t.notFound.kicker}</span>
      <h1 class="h1 !text-white">{t.notFound.title}</h1>
      <p class="lead !text-slate-300 mt-6 max-w-2xl">{t.notFound.lead}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={p('/')} class="btn btn-on-dark">{t.notFound.ctaPrimary}</a>
        <a href={p('/contact/')} class="btn btn-ghost-on-dark">{t.notFound.ctaSecondary}</a>
      </div>
    </div>
  </section>
</Base>
