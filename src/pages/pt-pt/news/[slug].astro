---
import Base from '../../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getDictionary } from '../../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'news'> }
const { post } = Astro.props;
const { Content } = await post.render();

const categoryLabel = (key: string): string =>
  (t.news.categories as Record<string, string>)[key] ?? key;

// Canonical always points to the EN blog post — per CTO spec, article bodies
// are EN-only across locales. Localised URLs display the same EN body with
// translated chrome.
const canonical = `https://aiso-group.com/news/${post.slug}/`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": { "@type": "Person", "name": post.data.author },
  "publisher": {
    "@type": "Organization",
    "name": "AISO Group",
    "url": "https://aiso-group.com"
  },
  "mainEntityOfPage": canonical,
  "inLanguage": "en"
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t.news.breadcrumbHome, "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": t.news.breadcrumbNews, "item": "https://aiso-group.com/news/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonical }
  ]
};

function fmt(d: Date, loc: Locale) {
  const tag = loc === 'pt-pt' ? 'pt-PT' : loc === 'fr' ? 'fr-FR' : 'en-GB';
  return d.toLocaleDateString(tag, { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title={post.data.title}
  description={post.data.description}
  canonicalUrl={canonical}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  hreflangDisabled={true}
>
  <article>
    <header class="bg-[#0A1628] text-white">
      <div class="container-aiso section !py-20 md:!py-24">
        <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-400">
          <a href={p('/')} class="hover:text-white">{t.news.breadcrumbHome}</a>
          <span class="mx-2">/</span>
          <a href={p('/news/')} class="hover:text-white">{t.news.breadcrumbNews}</a>
        </nav>
        <span class="kicker kicker-on-dark mb-4 block">
          {categoryLabel(post.data.category)}
        </span>
        <h1 class="h1 !text-white max-w-4xl">{post.data.title}</h1>
        <p class="text-sm text-slate-400 mt-6">
          {fmt(post.data.date, locale)} · {post.data.readTime} {t.news.card.readTimeSuffix} · {post.data.author}
        </p>
        {locale !== 'en' && (
          <p class="text-xs text-slate-400 mt-3 italic">{t.news.articleEnNotice}</p>
        )}
      </div>
    </header>

    <section class="bg-white">
      <div class="container-aiso section">
        <div class="article-body">
          <Content />
        </div>
        <div class="mt-12 pt-8 border-t border-slate-200 flex flex-col sm:flex-row gap-3 sm:justify-between items-start">
          <a href={p('/news/')} class="btn btn-ghost">{t.news.postBack}</a>
          <a href={`${p('/')}#router`} class="btn btn-primary">{t.news.postCta}</a>
        </div>
      </div>
    </section>
  </article>
</Base>
