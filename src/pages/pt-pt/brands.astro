---
import Base from '../../layouts/Base.astro';
import { getDictionary } from '../../i18n/routes';
import { localisePath, isLocale, defaultLocale, type Locale } from '../../i18n/config';

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);
const p = (slug: string) => localisePath(slug.startsWith('/') ? slug : `/${slug}`, locale);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aiso-group.com/" },
    { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://aiso-group.com/brands/" }
  ]
};
---

<Base
  title={t.brands.meta.title}
  description={t.brands.meta.description}
  jsonLd={breadcrumbJsonLd}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-28">
      <span class="kicker kicker-on-dark mb-5 block">{t.brands.hero.kicker}</span>
      <h1 class="h1 !text-white max-w-4xl">{t.brands.hero.title}</h1>
      <p class="lead !text-slate-300 mt-6">{t.brands.hero.lead}</p>
    </div>
  </section>

  {/* HUB */}
  <section class="bg-white">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="md:col-span-1">
          <div class="w-12 h-1.5 rounded-full mb-4" style="background: #00d492;"></div>
          <span class="kicker mb-2 block">{t.brands.hub.kicker}</span>
          <h2 class="h2 !text-[#0A1628]">{t.brands.hub.heading}</h2>
          <a href="https://aiso-hub.com" rel="noopener" class="btn btn-primary mt-6 !bg-[#00d492] hover:!bg-[#00b87c]">{t.brands.hub.cta}</a>
        </div>
        <div class="md:col-span-2 article-body">
          <p><strong>{t.brands.oneJob}</strong> {t.brands.hub.oneJob}</p>
          <p><strong>{t.brands.whatWeDo}</strong></p>
          <ul>
            <li>{t.brands.hub.do1}</li>
            <li>{t.brands.hub.do2}</li>
            <li>{t.brands.hub.do3}</li>
          </ul>
          <p><strong>{t.brands.whatWeDoNot}</strong></p>
          <ul>
            <li>{t.brands.hub.dont1}</li>
            <li>{t.brands.hub.dont2}</li>
          </ul>
          <p><strong>{t.brands.whoItFits}</strong> <span set:html={t.brands.hub.fits} /></p>
        </div>
      </div>
    </div>
  </section>

  {/* DEV */}
  <section class="bg-slate-50">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="md:col-span-1">
          <div class="w-12 h-1.5 rounded-full mb-4" style="background: #3B82F6;"></div>
          <span class="kicker mb-2 block">{t.brands.dev.kicker}</span>
          <h2 class="h2 !text-[#0A1628]">{t.brands.dev.heading}</h2>
          <a href="https://aiso-dev.com" rel="noopener" class="btn btn-primary mt-6 !bg-[#3B82F6] hover:!bg-[#2563EB]">{t.brands.dev.cta}</a>
        </div>
        <div class="md:col-span-2 article-body">
          <p><strong>{t.brands.oneJob}</strong> {t.brands.dev.oneJob}</p>
          <p><strong>{t.brands.whatWeDo}</strong></p>
          <ul>
            <li>{t.brands.dev.do1}</li>
            <li>{t.brands.dev.do2}</li>
            <li>{t.brands.dev.do3}</li>
          </ul>
          <p><strong>{t.brands.whatWeDoNot}</strong></p>
          <ul>
            <li>{t.brands.dev.dont1}</li>
            <li>{t.brands.dev.dont2}</li>
          </ul>
          <p><strong>{t.brands.whoItFits}</strong> <span set:html={t.brands.dev.fits} /></p>
        </div>
      </div>
    </div>
  </section>

  {/* BUZZ */}
  <section class="bg-white">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="md:col-span-1">
          <div class="w-12 h-1.5 rounded-full mb-4" style="background: #F97316;"></div>
          <span class="kicker mb-2 block">{t.brands.buzz.kicker}</span>
          <h2 class="h2 !text-[#0A1628]">{t.brands.buzz.heading}</h2>
          <a href="https://aiso-buzz.com" rel="noopener" class="btn btn-primary mt-6 !bg-[#F97316] hover:!bg-[#EA580C]">{t.brands.buzz.cta}</a>
        </div>
        <div class="md:col-span-2 article-body">
          <p><strong>{t.brands.oneJob}</strong> {t.brands.buzz.oneJob}</p>
          <p><strong>{t.brands.whatWeDo}</strong></p>
          <ul>
            <li>{t.brands.buzz.do1}</li>
            <li>{t.brands.buzz.do2}</li>
            <li>{t.brands.buzz.do3}</li>
          </ul>
          <p><strong>{t.brands.whatWeDoNot}</strong></p>
          <ul>
            <li>{t.brands.buzz.dont1}</li>
            <li>{t.brands.buzz.dont2}</li>
          </ul>
          <p><strong>{t.brands.whoItFits}</strong> <span set:html={t.brands.buzz.fits} /></p>
        </div>
      </div>
    </div>
  </section>

  {/* LEARN */}
  <section class="bg-slate-50">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="md:col-span-1">
          <div class="w-12 h-1.5 rounded-full mb-4" style="background: #8B5CF6;"></div>
          <span class="kicker mb-2 block">{t.brands.learn.kicker}</span>
          <h2 class="h2 !text-[#0A1628]">{t.brands.learn.heading}</h2>
          <a href="https://aiso-learn.com" rel="noopener" class="btn btn-primary mt-6 !bg-[#8B5CF6] hover:!bg-[#7C3AED]">{t.brands.learn.cta}</a>
        </div>
        <div class="md:col-span-2 article-body">
          <p><strong>{t.brands.oneJob}</strong> {t.brands.learn.oneJob}</p>
          <p><strong>{t.brands.whatWeDo}</strong></p>
          <ul>
            <li>{t.brands.learn.do1}</li>
            <li>{t.brands.learn.do2}</li>
            <li>{t.brands.learn.do3}</li>
          </ul>
          <p><strong>{t.brands.whatWeDoNot}</strong></p>
          <ul>
            <li>{t.brands.learn.dont1}</li>
            <li>{t.brands.learn.dont2}</li>
            <li>{t.brands.learn.dont3}</li>
          </ul>
          <p><strong>{t.brands.whoItFits}</strong> <span set:html={t.brands.learn.fits} /></p>
        </div>
      </div>
    </div>
  </section>

  {/* HOW TO CHOOSE */}
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section">
      <div class="max-w-3xl">
        <span class="kicker kicker-on-dark mb-3 block">{t.brands.howToChoose.kicker}</span>
        <h2 class="h2 !text-white">{t.brands.howToChoose.title}</h2>
        <div class="article-body mt-6 !text-slate-200 [&>p]:text-slate-300 [&_strong]:!text-white [&_a]:!text-white">
          <p set:html={t.brands.howToChoose.short} />
          <ul class="!text-slate-300">
            <li set:html={t.brands.howToChoose.bullet1} />
            <li set:html={t.brands.howToChoose.bullet2} />
            <li set:html={t.brands.howToChoose.bullet3} />
          </ul>
        </div>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href={`${p('/')}#router`} class="btn btn-on-dark">{t.brands.howToChoose.ctaPrimary}</a>
          <a href={p('/contact/')} class="btn btn-ghost-on-dark">{t.brands.howToChoose.ctaSecondary}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
