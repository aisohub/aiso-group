---
import Base from '../../../../layouts/Base.astro';
import { localisePath } from '../../../../i18n/config';
import { authors, authorSlugs } from '../../../../data/authors';

const locale = 'pt-pt' as const;
const p = (path: string) => localisePath(path.startsWith('/') ? path : `/${path}`, locale);
const pageUrl = 'https://aiso-group.com/pt-pt/about/team/';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://aiso-group.com/pt-pt/' },
    { '@type': 'ListItem', position: 2, name: 'Sobre', item: 'https://aiso-group.com/pt-pt/about/' },
    { '@type': 'ListItem', position: 3, name: 'Equipa', item: pageUrl },
  ],
};

const team = authorSlugs.map((slug) => authors[slug]);
---

<Base
  title="A equipa por trás do AISO Group"
  description="As pessoas por trás das quatro marcas especialistas em IA do AISO Group. Fundadores, leads e contributores nomeados em cada artigo."
  canonicalUrl={pageUrl}
  jsonLd={breadcrumbJsonLd}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-20 md:!py-24">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-400">
        <a href={p('/')} class="hover:text-white">Início</a>
        <span class="mx-2">/</span>
        <a href={p('/about/')} class="hover:text-white">Sobre</a>
        <span class="mx-2">/</span>
        <span class="text-white">Equipa</span>
      </nav>
      <h1 class="h1 !text-white max-w-4xl">A equipa por trás do AISO Group</h1>
      <p class="lead !text-slate-300 mt-6 max-w-3xl">
        As pessoas que constroem, escrevem e entregam nas nossas quatro marcas especialistas em IA. Cada artigo de news neste site é nomeado e verificável.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {team.map((author) => {
          const t = author.copy['pt-pt'];
          return (
            <article class="article-body">
              <h2 class="h3 !text-[#0A1628]">
                <a href={p(`/about/team/${author.slug}/`)} class="hover:underline">{author.name}</a>
              </h2>
              <p class="kicker mb-2 block">{t.jobTitle}</p>
              <p>{t.bio}</p>
              <p>
                <a href={p(`/about/team/${author.slug}/`)} class="underline">Ler bio completa →</a>
              </p>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Base>
