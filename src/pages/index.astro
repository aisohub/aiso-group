---
import Base from '../layouts/Base.astro';

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AISO Group",
  "alternateName": "AISO",
  "url": "https://aiso-group.com",
  "description": "Three specialist AI companies under one roof. AI search (Hub), AI systems (Dev), AI-powered social (Buzz).",
  "foundingDate": "2025",
  "foundingLocation": { "@type": "Place", "name": "Lisbon, Portugal" },
  "parentOrganization": {
    "@type": "Organization",
    "name": "Precious Episode LDA",
    "taxID": "PT516578506",
    "address": { "@type": "PostalAddress", "addressLocality": "Lisbon", "addressCountry": "PT" }
  },
  "subOrganization": [
    { "@type": "Organization", "name": "AISO Hub", "url": "https://aiso-hub.com", "description": "AI Search Optimization agency" },
    { "@type": "Organization", "name": "AISO Dev", "url": "https://aiso-dev.com", "description": "AI implementation partner for SMBs" },
    { "@type": "Organization", "name": "AISO Buzz", "url": "https://aiso-buzz.com", "description": "AI-powered social & content agency" }
  ],
  "founder": { "@type": "Person", "name": "Greg Stoos" },
  "contactPoint": { "@type": "ContactPoint", "email": "hello@aiso-group.com", "contactType": "customer service" }
};

const webSiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": "https://aiso-group.com",
  "name": "AISO Group",
  "publisher": { "@type": "Organization", "name": "AISO Group" }
};
---

<Base
  title="AISO Group — The specialist AI group for real businesses"
  description="Three specialist AI companies under one roof. AI search (Hub), AI systems (Dev), AI-powered social (Buzz). Pick the one that fits — expand when you are ready."
  jsonLd={[orgJsonLd, webSiteJsonLd]}
>
  <section class="bg-[#0A1628] text-white">
    <div class="container-aiso section !py-24 md:!py-32">
      <span class="kicker kicker-on-dark mb-5 block">Lisbon · 2026 · Specialist AI</span>
      <h1 class="h1 !text-white max-w-4xl">
        The specialist AI group for real businesses.
      </h1>
      <p class="lead !text-slate-300 mt-6">
        Three specialist AI companies under one roof. AI search. AI systems. AI-powered social. Pick the one that fits. Expand when you are ready.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row gap-3">
        <a href="#router" class="btn btn-on-dark">Find your AISO specialist →</a>
        <a href="/contact/" class="btn btn-ghost-on-dark">Talk to Greg →</a>
      </div>
    </div>
  </section>

  <section id="router" class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-2xl mb-10">
        <span class="kicker mb-3">The router</span>
        <h2 class="h2">Which AISO brand do I need?</h2>
        <p class="lead mt-4">Three questions. One specialist. A 20-second answer.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <article class="router-card" style="--accent: #00d492;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">Do I need to be found by AI?</p>
          <h3 class="router-card__answer">AISO Hub</h3>
          <p class="router-card__audience">
            We make your brand the answer ChatGPT, Perplexity, and Google AI Overviews cite. For businesses ready to own the AI search layer.
          </p>
          <a class="router-card__cta" href="https://aiso-hub.com" rel="noopener">Visit AISO Hub →</a>
        </article>

        <article class="router-card" style="--accent: #3B82F6;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">Do I need AI to run something in my business?</p>
          <h3 class="router-card__answer">AISO Dev</h3>
          <p class="router-card__audience">
            We build AI systems your team can operate — data pipelines, agent workflows, custom internal tools. For SMBs with a process, not a slide deck.
          </p>
          <a class="router-card__cta" href="https://aiso-dev.com" rel="noopener">Visit AISO Dev →</a>
        </article>

        <article class="router-card" style="--accent: #F97316;">
          <div class="router-card__accent"></div>
          <p class="router-card__question">Do I need content and social that sounds like my brand?</p>
          <h3 class="router-card__answer">AISO Buzz</h3>
          <p class="router-card__audience">
            We produce social and content backed by a brand bible, validated before it ships. For businesses without a marketing team who refuse to sound like AI.
          </p>
          <a class="router-card__cta" href="https://aiso-buzz.com" rel="noopener">Visit AISO Buzz →</a>
        </article>
      </div>

      <div class="mt-10 p-6 rounded-2xl border border-slate-200 bg-slate-50 flex flex-col sm:flex-row justify-between gap-4 items-start sm:items-center">
        <div>
          <p class="text-sm font-semibold text-[#0A1628]">Not sure which one fits?</p>
          <p class="text-sm text-slate-600 mt-1">Book a 20-minute call. We will route you.</p>
        </div>
        <a href="/contact/" class="btn btn-primary whitespace-nowrap">Talk to Greg →</a>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="container-aiso section">
      <span class="kicker mb-3 block">The verb test</span>
      <h2 class="h2 mb-8">One line each. Made visible.</h2>
      <div class="sibling-strip">
        <div class="sibling-strip__item" style="--accent: #00d492;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Hub cites</p>
          <p class="text-lg text-[#0A1628] mt-1">We make AI quote your brand.</p>
        </div>
        <div class="sibling-strip__item" style="--accent: #3B82F6;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Dev builds</p>
          <p class="text-lg text-[#0A1628] mt-1">We ship AI systems that run.</p>
        </div>
        <div class="sibling-strip__item" style="--accent: #F97316;">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Buzz says</p>
          <p class="text-lg text-[#0A1628] mt-1">We write content that sounds like you.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-aiso section">
      <div class="max-w-3xl">
        <span class="kicker mb-3 block">Founder note</span>
        <h2 class="h2 mb-6">Why a group, not a generalist</h2>
        <div class="article-body">
          <p>
            Generalist AI agencies fail small and mid-sized businesses. The work spreads thin. The team optimizes for hours, not outcomes.
          </p>
          <p>
            We built a group instead. Three specialist companies, each with one job.
          </p>
          <p>
            The advantage: you do not buy a bundle. You buy the specialist you need now. You bring in the others when the timing is right.
          </p>
          <p>
            Lisbon-based. EU-focused. Built in 2025.
          </p>
          <p class="text-sm text-slate-500 mt-6">— Greg Stoos, Founder. Lisbon, 2025.</p>
        </div>
        <div class="mt-8">
          <a href="/about/" class="btn btn-ghost">Read the thesis →</a>
        </div>
      </div>
    </div>
  </section>
</Base>
