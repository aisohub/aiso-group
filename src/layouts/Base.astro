---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage = '/og-default.png', canonicalUrl, jsonLd } = Astro.props;
const canonical = canonicalUrl ?? Astro.url.href;
const siteTitle = title.includes('AISO Group') ? title : `${title} | AISO Group`;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#0A1628" />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AISO Group" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a href="#main" class="skip-link">Skip to main content</a>

    <header class="sticky top-0 left-0 right-0 z-50 bg-[#0A1628]/95 backdrop-blur-sm border-b border-white/10">
      <nav class="container-aiso h-16 flex items-center justify-between" aria-label="Primary">
        <a href="/" class="flex items-center gap-2 group" aria-label="AISO Group — Home">
          <span class="text-lg font-bold text-white tracking-tight">
            AISO <span class="text-[#C7CFD8]">Group</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-7">
          <a href="/" class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">Home</a>
          <a href="/brands/" class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">Brands</a>
          <a href="/about/" class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">About</a>
          <a href="/news/" class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">News</a>
          <a href="/contact/" class="btn btn-on-dark !py-2 !px-3.5 !text-sm">Find your specialist →</a>
        </div>
        <button
          id="mobile-menu-btn"
          class="md:hidden text-white p-2 rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-2"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <div id="mobile-menu" class="hidden md:hidden bg-[#0A1628] border-t border-white/10 px-6 py-4">
        <div class="flex flex-col gap-3">
          <a href="/" class="text-slate-200 hover:text-white font-medium transition-colors py-1">Home</a>
          <a href="/brands/" class="text-slate-200 hover:text-white font-medium transition-colors py-1">Brands</a>
          <a href="/about/" class="text-slate-200 hover:text-white font-medium transition-colors py-1">About</a>
          <a href="/news/" class="text-slate-200 hover:text-white font-medium transition-colors py-1">News</a>
          <a href="/contact/" class="text-[#E5E9EE] hover:text-white font-semibold transition-colors py-1">Find your specialist →</a>
        </div>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="bg-[#0A1628] text-slate-300 border-t border-white/10 mt-auto">
      <div class="container-aiso py-12">
        <div class="mb-8">
          <span class="group-badge">Part of AISO Group</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
          <div>
            <div class="text-lg font-bold text-white mb-3">
              AISO <span class="text-[#C7CFD8]">Group</span>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed">
              Four specialist AI companies under one roof. AI search. AI systems. AI-powered social. AI training.
            </p>
            <p class="text-xs text-slate-300 mt-3">Lisbon, Portugal</p>
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Sibling brands</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href="https://aiso-hub.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">AISO Hub — AI Search</a></li>
              <li><a href="https://aiso-dev.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">AISO Dev — AI Systems</a></li>
              <li><a href="https://aiso-buzz.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">AISO Buzz — AI-Powered Social</a></li>
              <li><a href="https://aiso-learn.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">AISO Learn — AI Training</a></li>
            </ul>
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">AISO Group</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href="/" class="text-slate-300 hover:text-white transition-colors">Home</a></li>
              <li><a href="/brands/" class="text-slate-300 hover:text-white transition-colors">Brands</a></li>
              <li><a href="/about/" class="text-slate-300 hover:text-white transition-colors">About</a></li>
              <li><a href="/news/" class="text-slate-300 hover:text-white transition-colors">News & notes</a></li>
              <li><a href="/contact/" class="text-slate-300 hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Contact & legal</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href="mailto:hello@aiso-group.com" class="text-slate-300 hover:text-white transition-colors">hello@aiso-group.com</a></li>
              <li><a href="/privacy-policy/" class="text-slate-300 hover:text-white transition-colors">Privacy policy</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-3">
          <p class="text-xs text-slate-400">&copy; 2025–{new Date().getFullYear()} AISO Group · Precious Episode LDA · Lisbon, Portugal</p>
          <p class="text-xs text-slate-300">The specialist AI group for real businesses.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const hidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', hidden ? 'false' : 'true');
      });
    </script>
  </body>
</html>
