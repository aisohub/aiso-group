---
import '../styles/global.css';
import {
  locales as ALL_LOCALES,
  localeHtmlLang,
  localisePath,
  defaultLocale,
  isLocale,
  type Locale,
} from '../i18n/config';
import { getDictionary } from '../i18n/routes';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /**
   * When true, skip emitting hreflang alternates. Use for pages that only
   * exist in English (e.g. news article detail pages) - per spec, blog bodies
   * stay EN-only across locales and should not advertise language alternates.
   */
  hreflangDisabled?: boolean;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalUrl,
  jsonLd,
  hreflangDisabled = false,
} = Astro.props;

const locale: Locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale;
const t = getDictionary(locale);

// Canonical URL - strip query params to avoid UTM leakage.
const canonicalObj = new URL(Astro.url.pathname, Astro.site);
canonicalObj.search = '';
let canonical = canonicalUrl ?? canonicalObj.toString();
if (!canonical.endsWith('/')) canonical += '/';

const siteTitle = title.includes(t.meta.siteName) ? title : `${title} | ${t.meta.titleSuffix}`;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Build hreflang alternates for every locale by translating the current path.
const alternateLinks = !hreflangDisabled
  ? ALL_LOCALES.map((loc) => ({
      hreflang: localeHtmlLang[loc],
      href: new URL(localisePath(Astro.url.pathname, loc), Astro.site).toString(),
    }))
  : [];
const xDefaultHref = !hreflangDisabled
  ? new URL(localisePath(Astro.url.pathname, defaultLocale), Astro.site).toString()
  : null;

// Locale-aware internal paths used in nav + footer + CTAs.
const p = (slug: string) => {
  const base = slug.startsWith('/') ? slug : `/${slug}`;
  return localisePath(base, locale);
};

const year = new Date().getFullYear();
const copyright = t.footer.copyright.replace('{year}', String(year));
---

<!DOCTYPE html>
<html lang={localeHtmlLang[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#0A1628" />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {alternateLinks.map(({ href, hreflang }) => (
      <link rel="alternate" href={href} hreflang={hreflang} />
    ))}
    {xDefaultHref && <link rel="alternate" href={xDefaultHref} hreflang="x-default" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t.meta.siteName} />
    <meta property="og:locale" content={localeHtmlLang[locale].replace('-', '_')} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {import.meta.env.PROD && (
      <>
        <!-- Google tag (gtag.js) - GA4: defer until after first paint to reduce TBT -->
        <link rel="preconnect" href="https://www.googletagmanager.com" />
        <script is:inline>
          window.addEventListener('load', function () {
            var s = document.createElement('script');
            s.async = true;
            s.src = 'https://www.googletagmanager.com/gtag/js?id=G-P55SYHJ2TZ';
            document.head.appendChild(s);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-P55SYHJ2TZ');
          });
        </script>
      </>
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a href="#main" class="skip-link">{t.nav.skipToContent}</a>

    <header class="sticky top-0 left-0 right-0 z-50 bg-[#0A1628]/95 backdrop-blur-sm border-b border-white/10">
      <nav class="container-aiso h-16 flex items-center justify-between" aria-label={t.nav.primaryAriaLabel}>
        <a href={p('/')} class="flex items-center gap-2 group" aria-label={t.nav.homeAriaLabel}>
          <img src="/images/logo/aiso-group-negative.svg" alt="AISO Group" width="130" height="32" class="h-8 w-auto" />
        </a>
        <div class="hidden md:flex items-center gap-7">
          <a href={p('/')} class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">{t.nav.home}</a>
          <a href={p('/brands/')} class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">{t.nav.brands}</a>
          <a href={p('/about/')} class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">{t.nav.about}</a>
          <a href={p('/news/')} class="text-slate-200 hover:text-white text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-4 rounded">{t.nav.news}</a>
          <a href={p('/contact/')} class="btn btn-on-dark !py-2 !px-3.5 !text-sm">{t.nav.cta}</a>
          <LanguageSwitcher variant="header" />
        </div>
        <button
          id="mobile-menu-btn"
          class="md:hidden text-white p-2 rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C7CFD8] focus-visible:outline-offset-2"
          aria-label={t.nav.openMenu}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <div id="mobile-menu" class="hidden md:hidden bg-[#0A1628] border-t border-white/10 px-6 py-4">
        <div class="flex flex-col gap-3">
          <a href={p('/')} class="text-slate-200 hover:text-white font-medium transition-colors py-1">{t.nav.home}</a>
          <a href={p('/brands/')} class="text-slate-200 hover:text-white font-medium transition-colors py-1">{t.nav.brands}</a>
          <a href={p('/about/')} class="text-slate-200 hover:text-white font-medium transition-colors py-1">{t.nav.about}</a>
          <a href={p('/news/')} class="text-slate-200 hover:text-white font-medium transition-colors py-1">{t.nav.news}</a>
          <a href={p('/contact/')} class="text-[#E5E9EE] hover:text-white font-semibold transition-colors py-1">{t.nav.cta}</a>
          <LanguageSwitcher variant="footer" />
        </div>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="bg-[#0A1628] text-slate-300 border-t border-white/10 mt-auto">
      <div class="container-aiso py-12">
        <div class="mb-8">
          <span class="group-badge">{t.footer.partOf}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
          <div>
            <img src="/images/logo/aiso-group-white.svg" alt="AISO Group" width="150" height="36" class="h-9 w-auto mb-3" />
            <p class="text-sm text-slate-400 leading-relaxed">{t.footer.tagline}</p>
            <p class="text-xs text-slate-300 mt-3">{t.footer.location}</p>
            <LanguageSwitcher variant="footer" />
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">{t.footer.siblingBrandsHeading}</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href="https://aiso-hub.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">{t.footer.siblingHub}</a></li>
              <li><a href="https://aiso-dev.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">{t.footer.siblingDev}</a></li>
              <li><a href="https://aiso-buzz.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">{t.footer.siblingBuzz}</a></li>
              <li><a href="https://aiso-learn.com" rel="noopener" class="text-slate-300 hover:text-white transition-colors">{t.footer.siblingLearn}</a></li>
            </ul>
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">{t.footer.groupHeading}</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href={p('/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.linkHome}</a></li>
              <li><a href={p('/brands/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.linkBrands}</a></li>
              <li><a href={p('/about/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.linkAbout}</a></li>
              <li><a href={p('/news/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.linkNews}</a></li>
              <li><a href={p('/contact/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.linkContact}</a></li>
            </ul>
          </div>
          <div>
            <div class="text-xs font-semibold text-white uppercase tracking-wider mb-4">{t.footer.contactLegalHeading}</div>
            <ul class="flex flex-col gap-2 text-sm">
              <li><a href="mailto:hello@aiso-group.com" class="text-slate-300 hover:text-white transition-colors">hello@aiso-group.com</a></li>
              <li><a href={p('/privacy-policy/')} class="text-slate-300 hover:text-white transition-colors">{t.footer.privacyPolicy}</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-3">
          <p class="text-xs text-slate-400">&copy; {copyright}</p>
          <p class="text-xs text-slate-300">{t.footer.strapline}</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const hidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', hidden ? 'false' : 'true');
      });
    </script>
  </body>
</html>
